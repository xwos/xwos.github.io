&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;            &lt;span style=&#34;color:#666&#34;&gt;|&lt;/span&gt; Prev Frame           &lt;span style=&#34;color:#666&#34;&gt;|&lt;/span&gt;
